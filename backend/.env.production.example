# ─────────────────────────────────────────────────────────────────────────────
# Production environment variables template
# Copy → .env.production and fill in real values.
# .env.production is gitignored — set these in Render dashboard env vars.
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=production

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:<SUPABASE_DB_PASSWORD>@db.nnxyvwodgxbuiuutapsx.supabase.co:5432/postgres

# ── Redis (Upstash — use rediss:// for TLS) ───────────────────────────────────
REDIS_URL=rediss://default:<UPSTASH_PASSWORD>@enabling-panther-131374.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://enabling-panther-131374.upstash.io
UPSTASH_REDIS_REST_TOKEN=<UPSTASH_REST_TOKEN>

# ── Auth / JWT ────────────────────────────────────────────────────────────────
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Google / Gemini AI ────────────────────────────────────────────────────────
GOOGLE_API_KEY=<YOUR_GEMINI_API_KEY>

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://nnxyvwodgxbuiuutapsx.supabase.co
SUPABASE_KEY=<SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_STORAGE_BUCKET=resumes
SUPABASE_STORAGE_BUCKET_PUBLIC=false

# ── Frontend CORS ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://<YOUR_VERCEL_URL>.vercel.app

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Observability (optional) ──────────────────────────────────────────────────
SENTRY_DSN=

# ── ATS ───────────────────────────────────────────────────────────────────────
ATS_SCORE_THRESHOLD=65
